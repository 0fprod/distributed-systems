{
  "name": "distributed-systems",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*",
    "integration-tests"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "bun run --filter '*' test",
    "db:generate": "bun run --filter '@distributed-systems/database' db:generate",
    "db:push": "bun run --filter '@distributed-systems/database' db:push",
    "db:migrate": "bun run --cwd packages/database db:migrate",
    "db:setup": "bun run db:generate && bun run db:push"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@commitlint/types": "^19.8.0",
    "@eslint/js": "^9.20.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/bun": "latest",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "knip": "^5.0.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "semantic-release": "^24.2.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  }
}
