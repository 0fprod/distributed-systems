{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["semantic-release", "tailwindcss"],
  "workspaces": {
    "apps/frontend": {
      "entry": ["index.html"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/backend": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/worker": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/database": {
      "project": ["src/**/*.ts", "!src/generated/**"]
    }
  }
}
