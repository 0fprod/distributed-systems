{
  "name": "@distributed-systems/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#invoicing/*": "./src/modules/invoicing/*.ts",
    "#shared/*": "./src/modules/shared/*.ts",
    "#test/*": "./src/test/*.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@distributed-systems/database": "workspace:*",
    "@distributed-systems/logger": "workspace:*",
    "@distributed-systems/otel": "workspace:*",
    "@distributed-systems/rabbitmq": "workspace:*",
    "@distributed-systems/shared": "workspace:*"
  }
}
