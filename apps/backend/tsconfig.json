{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["bun"],
    "paths": {
      "#*": ["./src/*"]
    },
    "outDir": "dist",
    "rootDir": "src",
    // Apps do not publish type declarations — disable to avoid TS2742 portability
    // errors that arise when Elysia/jose types cannot be referenced by name.
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
