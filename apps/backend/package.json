{
  "name": "@distributed-systems/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#invoicing/*": "./src/modules/invoicing/*.ts",
    "#shared/*": "./src/shared/*.ts",
    "#users/*": "./src/modules/users/*.ts",
    "#test/*": "./src/test/*.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@distributed-systems/database": "workspace:*",
    "@distributed-systems/logger": "workspace:*",
    "@distributed-systems/rabbitmq": "workspace:*",
    "@distributed-systems/shared": "workspace:*",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/opentelemetry": "^1.4.0",
    "@opentelemetry/api": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "elysia": "^1.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0"
  }
}
