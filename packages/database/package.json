{
  "name": "@distributed-systems/database",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "build": "bun run db:generate && bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@distributed-systems/shared": "workspace:*",
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0"
  }
}
