// Discover all running Docker containers via the Docker socket.
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

// Extract useful labels from Docker container metadata.
discovery.relabel "docker_labels" {
  targets = discovery.docker.containers.targets

  // Strip leading slash from container name: /distributed-systems-backend-1 → distributed-systems-backend-1
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  // Map compose service label to a shorter "service" label: backend, worker, etc.
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
  }
}

// Stream logs from each container via the Docker API (no filesystem access needed).
loki.source.docker "default" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_labels.output
  forward_to = [loki.write.default.receiver]
}

// Push logs to Loki — same Docker network, so the hostname resolves.
loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
